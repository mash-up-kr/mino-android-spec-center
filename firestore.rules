rules_version = '2';
// MASC Firestore 보안규칙 — docs/data-model.md §3
// 1차 가드: role·전이 적법성·필드 잠금. 민감 전이(pr_open/merged/pr_closed)는
// Functions(Admin SDK, 규칙 우회)만 설정 가능 — 클라이언트는 위조 불가.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isDeveloper() { return signedIn() && myRole() == 'developer'; }
    function isDesigner()  { return signedIn() && myRole() == 'designer'; }

    // 사용자 프로필 — 본인만 작성, 로그인 사용자는 읽기(리뷰어 이름 표시용)
    // MVP: role 은 온보딩에서 본인이 선택(자체 서명). PR 권한은 GitHub 토큰이 별도 게이트.
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if request.auth.uid == uid;
      allow delete: if false;
    }

    match /features/{featureId} {
      allow read: if signedIn();

      // 생성: 개발자, 본인 명의, 초기 상태 spec_draft, PR 필드 비어있음
      allow create: if isDeveloper()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'spec_draft'
        && request.resource.data.prNumber == null;

      // ── 필드 잠금 헬퍼 (update 후 문서 request.resource.data vs 기존 resource.data) ──
      function unchanged(f) {
        return request.resource.data.get(f, null) == resource.data.get(f, null);
      }
      // 클라이언트는 prNumber 를 임의값으로 못 넣음: 그대로거나 null(무효화)만
      function prNumberOk() {
        return request.resource.data.get('prNumber', null) == resource.data.get('prNumber', null)
          || request.resource.data.get('prNumber', null) == null;
      }

      // 개발자 허용 상태 전이 (from → to). pr_open/merged/pr_closed 로의 전이는 없음(Functions 전용).
      function devTransitionOk(from, to) {
        return (to == from && from != 'spec_in_review')   // 상태유지 수정(내용/사유/plan) — 검토중은 read-only
          || (to == 'spec_in_review' && (from == 'spec_draft' || from == 'spec_changes_requested'))
          || (to == 'plan_drafted' && from == 'spec_approved')
          || (to == 'spec_draft' && (from == 'spec_approved' || from == 'plan_drafted' || from == 'pr_open' || from == 'merged'));
      }
      // 디자이너 허용 상태 전이 — 승인/반려/보충코멘트(상태유지)만
      function desTransitionOk(from, to) {
        return (to == 'spec_approved' && from == 'spec_in_review')
          || (to == 'spec_changes_requested' && from == 'spec_in_review')
          || (to == from && (from == 'spec_in_review' || from == 'spec_changes_requested'));
      }
      // 디자이너는 spec 내용 변경 불가 — status·reviews·updatedAt 만 건드림
      function desContentLocked() {
        return unchanged('createdBy') && unchanged('slug') && unchanged('title')
          && unchanged('specBody') && unchanged('specVersion') && unchanged('versionLog')
          && unchanged('planBody') && unchanged('planStale')
          && unchanged('assets') && unchanged('figmaSources')
          && unchanged('prNumber') && unchanged('prUrl');
      }

      // 수정:
      //  - 개발자: createdBy 불변 + prNumber 위조 불가 + 적법 전이 (검토중 read-only 는 전이표가 강제)
      //  - 디자이너: createdBy 불변 + 내용 잠금 + 승인/반려/코멘트 전이
      allow update: if
        (isDeveloper() && unchanged('createdBy') && prNumberOk()
          && devTransitionOk(resource.data.status, request.resource.data.status))
        || (isDesigner() && desContentLocked()
          && desTransitionOk(resource.data.status, request.resource.data.status));

      allow delete: if false;

      // 컨펌 이력 서브컬렉션(설계) — 디자이너만 추가, 누구나 읽기, 수정/삭제 불가
      match /reviews/{reviewId} {
        allow read: if signedIn();
        allow create: if isDesigner();
        allow update, delete: if false;
      }
    }
  }
}
